# ── 合约部署 ──────────────────────────────────
# 部署钱包私钥（不要加 0x 前缀也可以，ethers 会自动处理）
PRIVATE_KEY=your_deployer_private_key_here

# RPC（默认用公共节点，也可以换成 Infura/Alchemy 的 Avalanche 节点）
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# MAINNET_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# ── Fuji / Mainnet 上的项目角色地址（不填则默认用 deployer 地址，仅演示用）──
# VALIDATOR_1=0x...
# VALIDATOR_2=0x...
# VALIDATOR_3=0x...
# BENEFICIARY_1=0x...
# BENEFICIARY_2=0x...
# BENEFICIARY_3=0x...
